# 复制为 `.env` 并由你的进程加载，或在 shell 中 `set` / `export`（本仓库代码默认直接读操作系统环境变量）
#
#   Windows PowerShell 示例：
#     $env:DASHSCOPE_API_KEY = "sk-xxxxxxxx"
#
# Linux/macOS：
#     export DASHSCOPE_API_KEY="sk-xxxxxxxx"

# 【必填其一】阿里云 DashScope / 灵积 API Key，用于向量模型 text-embedding-v3 与对话模型（ChatTongyi）
DASHSCOPE_API_KEY=

# 【可选】若单独为通义 Chat 配置了变量，可读；否则 model/model.py 会回退使用 DASHSCOPE_API_KEY
# TONGYI_API_KEY=

# （可选）日志级别，middleware 与普通 logging 可参考此变量（若你希望后续接到 log 模块可自行扩展）
# LOGLEVEL=INFO
